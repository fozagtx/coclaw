{
  "name": "@coclaw/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "compile": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@coclaw/config": "workspace:*",
    "@coclaw/observability": "workspace:*",
    "@coclaw/shared-types": "workspace:*",
    "bullmq": "^5.58.5",
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "tsx": "^4.20.5",
    "vitest": "^3.2.4"
  }
}
